</div>

<script>
  // ── Replace with your deployed Apps Script Web App URL ──
  const SCRIPT_URL = "YOUR_APPS_SCRIPT_WEB_APP_URL_HERE";

  // ── Toggle "Other" fields ──
  function toggleOther(cbId, wrapId) {
    const cb = document.getElementById(cbId);
    const wrap = document.getElementById(wrapId);
    if (cb && wrap) {
      cb.addEventListener('change', () => {
        wrap.style.display = cb.checked ? 'block' : 'none';
      });
    }
  }
  toggleOther('disc-other-cb',  'disc-other-wrap');
  toggleOther('ai-tools-cb',    'ai-tools-wrap');
  toggleOther('sw-other-cb',    'sw-other-wrap');
  toggleOther('pt-other-cb',    'pt-other-wrap');

  // ── Helpers ──
  function showErr(id, show) {
    const el = document.getElementById(id);
    if (el) el.style.display = show ? 'block' : 'none';
  }

  function getChecked(name) {
    return Array.from(document.querySelectorAll(`input[name="${name}"]:checked`))
      .map(cb => cb.value).join(', ');
  }

  function validate() {
    let ok = true;

    const name = document.getElementById('fullName').value.trim();
    showErr('e-name', !name); if (!name) ok = false;

    const email = document.getElementById('email').value.trim();
    const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    showErr('e-email', !emailValid); if (!emailValid) ok = false;

    const discs = document.querySelectorAll('input[name="disciplines"]:checked');
    showErr('e-disc', discs.length === 0); if (discs.length === 0) ok = false;

    const exp = document.getElementById('experience').value;
    showErr('e-exp', !exp); if (!exp) ok = false;

    const start = document.getElementById('startDate').value;
    showErr('e-start', !start); if (!start) ok = false;

    return ok;
  }

  // ── Submit ──
  document.getElementById('form').addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!validate()) return;

    const btn = document.getElementById('submitBtn');
    btn.textContent = 'Submitting…';
    btn.disabled = true;

    // Build software string — append AI tool specifics if filled
    let software = getChecked('software');
    const aiText = document.getElementById('ai-tools-text').value.trim();
    if (aiText) software = software.replace('AI Tools', `AI Tools (${aiText})`);
    const swOther = document.getElementById('sw-other-text').value.trim();
    if (swOther) software = software.replace(/Other$/, `Other: ${swOther}`);

    // Build disciplines string
    let disciplines = getChecked('disciplines');
    const discOther = document.getElementById('disc-other-text').value.trim();
    if (discOther) disciplines = disciplines.replace(/Other$/, `Other: ${discOther}`);

    // Build project types string
    let projectTypes = getChecked('projectTypes');
    const ptOther = document.getElementById('pt-other-text').value.trim();
    if (ptOther) projectTypes = projectTypes.replace(/Other$/, `Other: ${ptOther}`);

    const payload = {
      submittedAt:  new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }),
      fullName:     document.getElementById('fullName').value.trim(),
      email:        document.getElementById('email').value.trim(),
      phone:        document.getElementById('phone').value.trim(),
      college:      document.getElementById('college').value.trim(),
      currentRole:  document.getElementById('currentRole').value.trim(),
      disciplines,
      software,
      experience:   document.getElementById('experience').value,
      projectTypes,
      startDate:    document.getElementById('startDate').value,
      portfolio:    document.getElementById('portfolio').value.trim(),
      resume:       document.getElementById('resume').value.trim(),
      ambitions:    document.getElementById('ambitions').value.trim(),
    };

    try {
      await fetch(SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      document.getElementById('form').style.display = 'none';
      document.getElementById('success').style.display = 'block';
      document.getElementById('success').scrollIntoView({ behavior: 'smooth' });
    } catch {
      btn.textContent = 'Apply to Ideaform →';
      btn.disabled = false;
      alert('Something went wrong. Please try again or reach us on WhatsApp.');
    }
  });
</script>
