    <hr class="div"/>

    <!-- ─ Portfolio & Resume ─ -->
    <div class="sec">Your Work</div>

    <div class="field">
      <label class="field-label" for="portfolio">Portfolio Link</label>
      <p class="field-hint">Behance, personal website, Google Drive folder, or any public link</p>
      <input type="url" id="portfolio" name="portfolio" placeholder="https://your-portfolio.com"/>
    </div>

    <div class="field">
      <label class="field-label" for="resume">Resume / CV Link</label>
      <p class="field-hint">Google Drive, Dropbox, or any shareable link to your resume</p>
      <input type="url" id="resume" name="resume" placeholder="https://drive.google.com/your-resume"/>
    </div>

    <hr class="div"/>

    <!-- ─ Ambitions ─ -->
    <div class="sec">Your Ambitions</div>

    <div class="field">
      <label class="field-label" for="ambitions">Where do you want to be in 5 years?</label>
      <p class="field-hint">We're looking for people who aim high. Tell us what drives you and what you want to achieve in your design career.</p>
      <textarea id="ambitions" name="ambitions" placeholder="Share your career aspirations, what excites you about design, and what kind of impact you want to make…"></textarea>
    </div>

    <!-- ─ Submit ─ -->
    <div class="submit-row">
      <button type="submit" id="submitBtn">Apply to Ideaform &rarr;</button>
      <p class="submit-note">Your information is used only for recruitment purposes and kept strictly confidential.</p>
    </div>

    <div id="success">
      <h3>Thank you for applying.</h3>
      <p>We've received your application and will reach out if your profile is a strong match.<br/>Welcome to our orbit.</p>
    </div>

  </form>

